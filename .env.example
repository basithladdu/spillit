# Mapbox Access Token
# Get your token from https://account.mapbox.com/access-tokens/
# The application already has a working token configured as fallback
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Roboflow API Key
# Required for pothole detection
# Get your key from https://roboflow.com/
VITE_ROBOFLOW_API_KEY=
ROBOFLOW_API_KEY=
