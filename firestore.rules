rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin claim
    function isMunicipalAdmin() {
      return request.auth != null && request.auth.token.municipal_admin == true;
    }
    
    function isOpsAdmin() {
      // For now, allow any authenticated user to act as ops if they know the route
      // In production, check specific UID or claim: request.auth.token.admin == true
      return request.auth != null; 
    }

    // Municipal Registrations
    match /municipal_registrations/{regId} {
      // Allow anyone to create (public form)
      allow create: if true;
      // Only ops can read/update
      allow read, update: if isOpsAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isOpsAdmin());
      allow write: if isOpsAdmin();
    }

    // Issues
    match /issues/{issueId} {
      allow read, write: if true;
    }
  }
}
